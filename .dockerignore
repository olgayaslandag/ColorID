# =============================================================================
# Docker Ignore for Laravel Photo Builder Platform
# Excludes non-essential and sensitive files from Docker build context
# =============================================================================

# =============================================================================
# Dependencies (handled by Composer inside container or mounted as volumes)
# =============================================================================
vendor/
node_modules/

# =============================================================================
# Environment & Configuration (never shipped into the image)
# =============================================================================
.env
.env.backup
.env.production
.env.example

# =============================================================================
# Version Control
# =============================================================================
.git/
.gitattributes
.gitignore
.gitkeep
.gitmodules

# =============================================================================
# IDE & Editor Files
# =============================================================================
.idea/
.vscode/
.nova/
.zed/
/.cursor/
/.codex
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Build Artifacts
# =============================================================================
public/build/
public/hot
public/storage
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Laravel Specific
# =============================================================================
/storage/*.key
/storage/pail
/storage/logs/laravel.log
/bootstrap/cache/*.php
!bootstrap/cache/.gitignore

# =============================================================================
# Tests & CI
# =============================================================================
.phpunit.cache
.phpunit.result.cache
.phpactor.json
auth.json

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db
*.log
*.pid

# =============================================================================
# Docker (avoid recursive context)
# =============================================================================
docker-compose.yml
docker-compose*.yml
.dockerignore

# =============================================================================
# Documentation
# =============================================================================
README.md
CHANGELOG.md
CONTRIBUTING.md

# =============================================================================
# Frontend (already in node_modules)
# =============================================================================
package-lock.json
yarn.lock
tsconfig.json
vite.config.js
